# 邮箱配置（推荐使用 QQ 邮箱 SMTP）
# SMTP 服务器地址 (如 QQ 邮箱: smtp.qq.com)
SMTP_SERVER=smtp.qq.com
# SMTP 端口 (SSL 通常为 465)
SMTP_PORT=465
# 发件人邮箱地址
SENDER=your_email@qq.com
# 邮箱授权码 (注意不是登录密码)
PASSWORD=your_authorization_code
# 收件人邮箱 (多个用逗号分隔)
RECEIVER=receiver1@example.com,receiver2@example.com

# 定时任务配置
# 每日执行的小时 (0-23)
SCHEDULER_HOUR=9
# 每日执行的分钟 (0-59)
SCHEDULER_MINUTE=30

# 东方财富 API 配置
# 人气榜接口 (POST)
EASTMONEY_HOT_LIST_URL=https://emappdata.eastmoney.com/stockrank/getAllCurrentList
# 搜索建议接口 (GET, 用于获取股票名称/板块代码)
EASTMONEY_SUGGEST_URL=https://searchapi.eastmoney.com/api/suggest/get
# K线数据接口 (GET)
EASTMONEY_KLINE_URL=https://push2his.eastmoney.com/api/qt/stock/kline/get
# 通用列表接口 (GET, 用于获取板块成分股/涨幅榜)
EASTMONEY_CLIST_URL=https://push2.eastmoney.com/api/qt/clist/get
# 请求超时时间(秒)
EASTMONEY_TIMEOUT=5
# 接口认证 Token (固定值)
EASTMONEY_TOKEN=D43BF722C8E33BDC906FB84D85E326E8
# 接口认证 UT (固定值)
EASTMONEY_UT=bd1d9ddb04089700cf9c27f6f7426281
# 接口认证 Global ID (固定值)
EASTMONEY_GLOBAL_ID=786e4c21-70dc-435a-93bb-38

# MiniQMT 配置
# MiniQMT 安装路径 (例如: C:/国金证券QMT交易端/userdata_mini)
# 路径需要指向 MiniQMT 的 userdata_mini 目录
MINQMT_PATH=
# 会话ID，用于区分不同的连接 (整数，如 0, 1, 2...)
MINQMT_SESSION_ID=0
# 资金账号 (QMT 登录的资金账号)
MINQMT_ACCOUNT_ID=
# 是否启用 MiniQMT 作为数据源 (true/false)
MINQMT_ENABLED=false
# 数据源优先级: minqmt 或 eastmoney
# minqmt - 优先使用 MiniQMT，失败时回退到东方财富
# eastmoney - 优先使用东方财富
DATA_SOURCE_PRIORITY=minqmt
